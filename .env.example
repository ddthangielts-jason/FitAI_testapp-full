# ═══════════════════════════════════════════════
# FitAI — Biến môi trường (thêm ở Vercel → Settings → Environment Variables)
# ═══════════════════════════════════════════════

# App URL (domain Vercel thật của bạn)
APP_URL=https://fit-ai-testapp-full.vercel.app

# ── AI (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── PayOS (thanh toán chính) — lấy ở https://my.payos.vn ──
PAYOS_CLIENT_ID=...
PAYOS_API_KEY=...
PAYOS_CHECKSUM_KEY=...

# ── MoMo (tuỳ chọn — chỉ khi tài khoản MoMo Business đã duyệt) ──
MOMO_PARTNER_CODE=...
MOMO_ACCESS_KEY=...
MOMO_SECRET_KEY=...
MOMO_ENV=sandbox   # đổi thành "production" khi chạy thật

# ── Vercel KV (Redis) — BẮT BUỘC: lưu Pro + quota AI ──
# Tạo: Vercel → Storage → KV → Connect to Project (2 biến dưới tự thêm)
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
