# ═══════════════════════════════════════════════
# FitAI Environment Variables
# Sao chép file này thành .env.local để dev
# Thêm vào Vercel Dashboard → Settings → Env Vars
# ═══════════════════════════════════════════════

# App
APP_URL=https://your-app.vercel.app

# AI (Anthropic) - dùng cho coach tips
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────
# PAYOS (Recommended cho VN)
# Đăng ký: https://business.payos.vn
# ──────────────────────────────
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# ──────────────────────────────
# MOMO (Alternative)
# Đăng ký: https://business.momo.vn
# Test sandbox: https://developers.momo.vn/v3/
# ──────────────────────────────
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
MOMO_ENV=sandbox   # hoặc production

# ──────────────────────────────
# DATABASE (để lưu premium users)
# Option A - Vercel KV (Redis, free 30k req/mo)
# Option B - Supabase (free tier)
# Option C - PlanetScale (MySQL, free)
# ──────────────────────────────
# VERCEL_KV_URL=...
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...

# ──────────────────────────────
# VERCEL KV (Redis) — BẮT BUỘC cho production
# Bật quota (giới hạn lượt AI/user) + cache kết quả.
# Tạo: Vercel Dashboard → Storage → KV → Create Database → Connect to project
# Vercel sẽ tự thêm 2 biến dưới đây vào project. KHÔNG cần điền tay.
# Nếu thiếu 2 biến này: /api/ai vẫn chạy nhưng KHÔNG giới hạn quota (rủi ro chi phí).
# ──────────────────────────────
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
